{
  "defaultSeverity": "error",
  "extends": [
    "tslint:recommended"
  ],
  "jsRules": {},
  "rules": {
    "semicolon": [true, "always"],
    "quotemark": [true, "double"],
    "trailing-comma": [false],
    "no-console": false,
    "no-var-requires": false,
    "object-literal-sort-keys": false
  },
  "rulesDirectory": []
}
